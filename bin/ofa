#!/usr/bin/env ruby

# --- Bundler Setup ---
# This ensures that if we are in a project with a Gemfile, we use the correct 
# gem versions specified in Gemfile.lock, preventing conflicts with system gems.
if File.exist?(File.join(Dir.pwd, 'Gemfile'))
  begin
    require 'bundler/setup'
  rescue LoadError
    # Bundler not installed, proceed without it
  end
end

require 'fileutils'
require 'optparse'
require 'json'

# Framework core path
FRAMEWORK_ROOT = File.expand_path('..', __dir__)
# Current project path (where the user is running the command)
PROJECT_ROOT = Dir.pwd

# Load dotenv from project root if exists
begin
  require 'dotenv'
  Dotenv.load(File.join(PROJECT_ROOT, '.env'))
rescue LoadError
end

def help
  puts "                                            "
  puts "   ____  _______  ___                       "
  puts "  / __ \\/ ____/  /   |                      "
  puts " / / / / /_     / /| |  Framework           "
  puts "/ /_/ / __/    / ___ |  Premium MVC         "
  puts "\\____/_/      /_/  |_|  v5.3.0              "
  puts "                                            "
  puts "✨ One-For-All Framework CLI ✨"
  puts "-----------------------------"
  puts "Usage:"
  puts "  ofa new NAME [TYPE]   - Create a new project + automatic bundle install"
  puts "  ofa init [TYPE]       - Initialize project in current folder"
  puts "  ofa g controller NAME - Generate a new controller"
  puts "  ofa g api NAME        - Generate a new API controller (JSON)"
  puts "  ofa g model NAME      - Generate a new model"
  puts "  ofa g migration NAME  - Generate a new migration"
  puts "  ofa g mailer NAME ACTION - Generate a new mailer and template"
  puts "  ofa g task NAME       - Generate a new background task"
  puts "  ofa g test NAME       - Generate a new unit test"
  puts "  ofa g post TITLE      - Create a new post [args: --category, --author, --image]"
  puts "  ofa feature ACTION F  - Toggle features: action=enable/disable, F=cms/auth/rich_text"
  puts "  ofa type NAME         - Set application type: portfolio, blog, landing_page, e_commerce"
  puts "  ofa theme NAME        - Set UI theme: light_glass, dark_glass, cyber_sidebar, retro_terminal, light_sidebar"
  puts "  ofa storage NAME      - Set image storage: local, cloudinary"
  puts "  ofa reset-password USR PWD - Reset admin account password"
  puts "  ofa db switch TYPE [NAME] - Switch DB: sqlite, mysql, mariadb, mongodb, postgres"
  puts "  ofa db migrate-data TYPE [NAME] - Migrate data to another DB"
  puts "  ofa db migrate        - Run database migrations"
  puts "  ofa migrate           - Run database migrations (alias for db migrate)"
  puts "  ofa console           - Start interactive REPL session"
  puts "  ofa doctor            - Check system health (DB, config, gems)"
  puts "  ofa routes            - List all registered routes"
  puts "  ofa swagger           - Auto-generate OpenAPI/Swagger documentation"
  puts "  ofa maintenance ACTION - Toggle maintenance mode (on/off)"
  puts "  ofa task NAME         - Run a background task"
  puts "  ofa test              - Run all application tests"
  puts "  ofa run               - Start the application server"
  puts "  ofa deploy            - Deploy project to production"
  puts "-----------------------------"
  exit
end

def run_migrations
  Object.const_set(:APP_ROOT, PROJECT_ROOT) unless defined?(APP_ROOT)
  ENV['SKIP_MODELS'] = '1'
  require File.join(FRAMEWORK_ROOT, 'config', 'boot')
  puts "Running migrations..."
  migration_path = File.join(PROJECT_ROOT, "db/migrations")
  FileUtils.mkdir_p(migration_path)
  
  if defined?(DB) && DB
    if Dir.glob(File.join(migration_path, '*.rb')).empty?
      puts "No custom migrations found in #{migration_path}."
      puts "Core tables are automatically created. You're ready to go!"
    else
      Sequel.extension :migration
      Sequel::Migrator.run(DB, migration_path)
      puts "Migrations completed."
    end
  end
end

def perform_db_migration(target_type, target_name)
  # 1. Initialize source environment
  Object.const_set(:APP_ROOT, PROJECT_ROOT) unless defined?(APP_ROOT)
  ENV['SKIP_MODELS'] = '1'
  require File.join(FRAMEWORK_ROOT, 'config', 'boot')
  source_db = DB
  
  puts "📦 Starting data migration: #{DB_CONFIG['adapter']} -> #{target_type}..."

  # 2. Setup target connection
  target_db = nil
  target_mongo = nil

  if ['mongodb', 'mongo'].include?(target_type)
    require 'mongo'
    target_mongo = Mongo::Client.new(target_name)
    target_db = Sequel.connect("sqlite://db/data.sqlite3")
  elsif target_type == 'sqlite'
    target_db = Sequel.connect("sqlite://#{target_name || 'db/production.sqlite3'}")
  else
    target_db = Sequel.connect("#{target_type}://root:@localhost/#{target_name}")
  end

  # 3. Ensure target tables exist
  if target_db
    target_db.extension :pagination
    # Re-use the schema creation logic by mimicking a mini-boot
    # For simplicity, we'll just create core tables if they don't exist
    [:users, :pages, :posts, :projects, :products].each do |table|
      unless target_db.table_exists?(table)
        # Copy schema from source (very basic approach)
        schema = source_db.schema(table)
        target_db.create_table(table) do
          schema.each do |col_name, col_info|
            column col_name, col_info[:db_type], primary_key: col_info[:primary_key], allow_null: col_info[:allow_null]
          end
        end
      end
    end
  end

  # 4. Migrate data
  [:users, :pages, :posts, :projects, :products].each do |table|
    print "  Migrating #{table}... "
    rows = []
    
    # Try fetching from Mongo if it exists
    source_mongo = defined?(MONGO_CLIENT) ? MONGO_CLIENT : nil
    if source_mongo
      begin
        mongo_rows = source_mongo[table].find.to_a
        if mongo_rows.any?
          rows = mongo_rows.map do |r|
            r[:id] = r[:_id].to_s if r[:_id]
            r.delete(:_id)
            r
          end
        end
      rescue
        # Collection might not exist in Mongo, fallback to SQL
      end
    end

    # Fallback to SQL if no rows found in Mongo
    if rows.empty?
      begin
        rows = source_db[table].all
      rescue
        rows = []
      end
    end

    # Clear target table before migrating to avoid duplicates
    if target_db && target_db.table_exists?(table)
      target_db[table].delete
    end

    count = 0
    rows.each do |row|
      if target_type == 'mongodb' && table == :users
        # Users go to Mongo in Mongo mode
        target_mongo[:users].update_one({ username: row[:username] }, { "$set" => row.reject{|k| k == :id} }, { upsert: true })
      elsif target_db
        # Deep cleaning and type conversion for SQLite compatibility
        target_columns = target_db[table].columns
        clean_row = {}
        row.each do |k, v|
          sym_k = k.to_sym
          if target_columns.include?(sym_k) && sym_k != :id
            if v.is_a?(BSON::ObjectId)
              clean_row[sym_k] = v.to_s
            elsif v.is_a?(Time)
              clean_row[sym_k] = v.strftime('%Y-%m-%d %H:%M:%S')
            else
              clean_row[sym_k] = v
            end
          end
        end
        target_db[table].insert(clean_row)
      end
      count += 1
    end
    puts "#{count} rows."
  end

  # 5. Update configuration to point to new DB
  absolute_ofa_path = File.expand_path(__FILE__)
  system("ruby #{absolute_ofa_path} db switch #{target_type} \"#{target_name}\"")

  puts "✅ Migration successful!"
end

def ensure_initialized!
  config_path = File.join(PROJECT_ROOT, 'config', 'features.json')
  unless File.exist?(config_path)
    puts "❌ Error: Project not initialized in this folder."
    puts "   Please run 'ofa init' first."
    exit 1
  end
end

command = ARGV.shift
help if command.nil? || ['help', '-h', '--help'].include?(command)

case command
when 'new'
  project_name = ARGV.shift
  app_type = ARGV.shift || 'landing_page'
  if project_name.nil? || project_name.empty?
    puts "Usage: ofa new PROJECT_NAME [TYPE]"
    exit 1
  end
  target_dir = File.join(PROJECT_ROOT, project_name)
  if Dir.exist?(target_dir)
    puts "❌ Folder '#{project_name}' already exists."
    exit 1
  end
  FileUtils.mkdir_p(target_dir)
  puts "✨ Creating new project '#{project_name}' (#{app_type})..."
  # Delegate to 'init' logic by re-invoking ofa in the new directory using absolute path
  absolute_ofa_path = File.expand_path(__FILE__)
  system("cd #{target_dir} && ruby #{absolute_ofa_path} init #{app_type}")
  puts "📦 Running bundle install..."
  success = system("cd #{target_dir} && bundle install --quiet")
  if success
    puts ""
    puts "✅ Project '#{project_name}' is ready!"
    puts "   cd #{project_name} && ofa run"
  else
    puts "⚠️  bundle install failed. Please run it manually in folder #{project_name}."
  end

when 'init'
  app_type = ARGV.shift || 'landing_page'
  puts "                                            "
  puts "   ____  _______  ___                       "
  puts "  / __ \\/ ____/  /   |                      "
  puts " / / / / /_     / /| |  Framework           "
  puts "/ /_/ / __/    / ___ |  Premium MVC         "
  puts "\\____/_/      /_/  |_|  v5.3.0              "
  puts "                                            "
  puts "Initializing One-For-All project as '#{app_type}' in #{PROJECT_ROOT}..."

  # --- Interactive Wizard ---
  puts "\n🛠️  Project Configuration (Press Enter for default)"
  
  # 1. Database Configuration
  print "💾 Choose Database [1. SQLite (default), 2. MongoDB Atlas]: "
  db_choice = STDIN.gets.chomp
  db_type = db_choice == '2' ? 'mongodb' : 'sqlite'
  
  db_url = ""
  if db_type == 'mongodb'
    print "🔗 Enter MongoDB Connection String: "
    db_url = STDIN.gets.chomp
  end

  # 2. Image Storage Configuration
  print "🖼️ Choose Image Storage [1. Local (default), 2. Cloudinary]: "
  img_choice = STDIN.gets.chomp
  img_storage = img_choice == '2' ? 'cloudinary' : 'local'
  
  cloudinary_url = ""
  if img_storage == 'cloudinary'
    print "☁️ Enter Cloudinary URL (cloudinary://KEY:SECRET@NAME): "
    cloudinary_url = STDIN.gets.chomp
  end
  puts "-----------------------------\n"

  # Create directories
  dirs = ['app/controllers', 'app/models', 'app/views', 'app/mailers', 'lib/tasks', 'test', 'config', 'db/migrations', 'public/css', 'public/js', 'public/images', 'public/images/uploads']
  dirs.each { |dir| FileUtils.mkdir_p(File.join(PROJECT_ROOT, dir)) }
  
  # Copy framework core migrations
  framework_migrations = File.join(FRAMEWORK_ROOT, 'db/migrations')
  project_migrations = File.join(PROJECT_ROOT, 'db/migrations')
  if File.directory?(framework_migrations)
    Dir.glob(File.join(framework_migrations, '*.rb')).each do |mig|
      FileUtils.cp(mig, project_migrations)
    end
  end

  # Copy framework core helpers and test assets
  ['lib/task_helper.rb', 'app/mailers/application_mailer.rb', 'test/test_helper.rb'].each do |file|
    src = File.join(FRAMEWORK_ROOT, file)
    dest = File.join(PROJECT_ROOT, file)
    FileUtils.mkdir_p(File.dirname(dest))
    if File.exist?(src)
      content = File.read(src)
      # Inject FRAMEWORK_ROOT into test_helper.rb
      if file == 'test/test_helper.rb'
        content.gsub!("require_relative '../config/boot'", "$LOAD_PATH.unshift '#{FRAMEWORK_ROOT}'\nrequire 'config/boot'")
      end
      File.write(dest, content)
    end
  end

  # Standard project files
  ['.env.example', '.gitignore', 'Dockerfile', 'LICENSE', 'README.md', 'Procfile'].each do |file|
    src = File.join(FRAMEWORK_ROOT, file)
    dest = File.join(PROJECT_ROOT, file)
    if File.exist?(src)
      FileUtils.cp(src, dest)
      puts "  Creating #{file}..."
    end
  end

  # Create .env
  env_content = []
  env_content << "EKS_ENV=development"
  env_content << "DATABASE_URL=#{db_url}" if db_type == 'mongodb'
  env_content << "CLOUDINARY_URL=#{cloudinary_url}" if img_storage == 'cloudinary'
  env_content << "JWT_SECRET=#{Array.new(32){[*'0'..'9',*'a'..'z',*'A'..'Z'].sample}.join}"
  File.write(File.join(PROJECT_ROOT, '.env'), env_content.join("\n"))

  # Create config.ru
  puts "  Creating system files..."
  config_ru_content = <<~RUBY
    # Generated by One-For-All CLI
    # Target framework: #{FRAMEWORK_ROOT}
    
    # Add framework to load path dynamically
    require 'bundler/setup'
    framework_spec = Gem.loaded_specs['one-for-all-framework']
    if framework_spec
      $LOAD_PATH.unshift framework_spec.full_gem_path
    else
      # Fallback for local development if not in bundle (though it should be)
      $LOAD_PATH.unshift '#{FRAMEWORK_ROOT}'
    end

    APP_ROOT = File.expand_path(__dir__)
    require 'config/boot'
    
    # Middleware setup
    use EksCent::Middleware::ShowExceptions
    use EksCent::Middleware::Session, secret: EksCent.secret_key_base
    use MaintenanceMiddleware
    use AuthMiddleware
    use JwtMiddleware
    use CSRFMiddleware
    use EksCent::Middleware::Static, root: 'public'
    use EksCent::Middleware::Logger
    
    # Apply plugin routes
    OFA.apply_pending_routes(ROUTES) if defined?(OFA)
    
    run ROUTES
  RUBY
  File.write(File.join(PROJECT_ROOT, 'config.ru'), config_ru_content)

  # Create Gemfile
  gemfile_content = <<~RUBY
    source 'https://rubygems.org'
    
    gem 'one-for-all-framework', '5.3.0'
    gem 'eks-cent', '4.0.0'
    gem 'eksa-server'
    gem 'sequel'
    gem 'sqlite3'
    gem 'bcrypt'
    gem 'dotenv'
    gem 'cloudinary'
    gem 'mongo'
    gem 'mysql2'
    gem 'kramdown'
    gem 'kramdown-parser-gfm'
    gem 'mail'
    gem 'minitest'
  RUBY
  File.write(File.join(PROJECT_ROOT, 'Gemfile'), gemfile_content)

  # Create base ApplicationController
  app_controller_content = <<~'RUBY'
    class ApplicationController
      attr_reader :req, :res
      
      def initialize(req, res)
        @req = req
        @res = res
      end
      
      def params
        @req.params
      end
      
      def session
        @req.env['eks_cent.session'] ||= {}
      end
      
      def render(template, **locals)
        # Pass controller instance variables to the view
        instance_variables.each do |var|
          locals[var.to_s.delete('@').to_sym] ||= instance_variable_get(var)
        end
        @res.render(template, **locals)
      end
      
      def redirect_to(path)
        @res.status = 302
        @res.headers['Location'] = path
      end
      
      # Validation Helper
      def validate!(required_params)
        missing = required_params.select { |p| params[p.to_s].nil? || params[p.to_s].empty? }
        unless missing.empty?
          @res.status = 400
          render 'error', message: "Missing required parameters: #{missing.join(', ')}"
          throw(:halt)
        end
      end
      
      # CSRF Helper for views
      def csrf_token
        @req.env['eks_cent.csrf_token']
      end
    end
  RUBY
  File.write(File.join(PROJECT_ROOT, 'app/controllers/application_controller.rb'), app_controller_content)

  # Setup features.json
  config_path = File.join(PROJECT_ROOT, 'config', 'features.json')
  unless File.exist?(config_path)
    default_config = { 
      "auth" => true, 
      "cms" => true, 
      "type" => app_type, 
      "theme" => "dark_glass",
      "storage" => img_storage
    }
    File.write(config_path, JSON.pretty_generate(default_config))
  end

  # Setup database.json
  db_config_path = File.join(PROJECT_ROOT, 'config', 'database.json')
  unless File.exist?(db_config_path)
    if db_type == 'mongodb'
      db_default = { "adapter" => "env" }
    else
      db_default = { "adapter" => "sqlite", "database" => "db/development.sqlite3" }
    end
    File.write(db_config_path, JSON.pretty_generate(db_default))
  end

  # Copy views from framework to project
  framework_views = File.join(FRAMEWORK_ROOT, 'app', 'views')
  project_views = File.join(PROJECT_ROOT, 'app', 'views')
  
  # Recursive copy for views (including cms folder)
  FileUtils.cp_r(File.join(framework_views, '.'), project_views)
  
  # Copy public assets from framework to project
  framework_public = File.join(FRAMEWORK_ROOT, 'public')
  project_public = File.join(PROJECT_ROOT, 'public')
  if File.directory?(framework_public)
    # Use cp_r with '.' to copy contents of public, not the public folder itself
    FileUtils.cp_r(File.join(framework_public, '.'), project_public)
  end
  
  # Copy models from framework to project
  framework_models = File.join(FRAMEWORK_ROOT, 'app', 'models')
  project_models = File.join(PROJECT_ROOT, 'app', 'models')
  FileUtils.cp_r(File.join(framework_models, '.'), project_models)

  # Copy controllers from framework to project
  framework_controllers = File.join(FRAMEWORK_ROOT, 'app', 'controllers')
  project_controllers = File.join(PROJECT_ROOT, 'app', 'controllers')
  # Filter out specific internal framework controllers if needed, but here we want them
  Dir.glob(File.join(framework_controllers, '*.rb')).each do |file|
    # Skip ApplicationController because we generated a custom one for the project
    next if File.basename(file) == 'application_controller.rb'
    FileUtils.cp(file, project_controllers)
  end

  # Ensure public/css exists but we no longer rely on style.css for layout
  css_dir = File.join(PROJECT_ROOT, 'public/css')
  FileUtils.mkdir_p(css_dir)
  File.write(File.join(css_dir, 'style.css'), "/* Custom styles here. Framework uses layout.erb for core UI. */")

  # Scaffolding based on type
  case app_type
  when 'blog'
    puts "  Scaffolding Blog starter..."
    File.write(File.join(PROJECT_ROOT, 'app/controllers/posts_controller.rb'), <<~RUBY)
      require_relative 'application_controller'
      class PostsController < ApplicationController
        def index; end
      end
    RUBY
  when 'e_commerce'
    puts "  Scaffolding E-Commerce starter..."
    File.write(File.join(PROJECT_ROOT, 'app/controllers/products_controller.rb'), <<~RUBY)
      require_relative 'application_controller'
      class ProductsController < ApplicationController
        def index; end
      end
    RUBY
  end

  puts "Done! Run 'ofa run' to start your app."

when 'g'
  ensure_initialized!
  sub = ARGV.shift
  name = ARGV.shift
  if sub == 'controller' && name
    class_name = name.capitalize + "Controller"
    file_name = File.join(PROJECT_ROOT, "app/controllers/#{name.downcase}_controller.rb")
    content = <<~RUBY
      require_relative 'application_controller'

      class #{class_name} < ApplicationController
        def index
          # Logic for #{name}
          render_json({ message: "Welcome to #{class_name}" })
        end
      end
    RUBY
    File.write(file_name, content)
    puts "Created: #{file_name}"
  elsif sub == 'api' && name
    class_name = name.capitalize + "Controller"
    file_name = File.join(PROJECT_ROOT, "app/controllers/#{name.downcase}_controller.rb")
    content = <<~RUBY
      require_relative 'api_controller'

      class #{class_name} < ApiController
        # GET /api/#{name.downcase}
        def index
          render_json({ 
            status: 'success', 
            message: "API endpoint for #{name} ready",
            data: [] 
          })
        end

        # POST /api/#{name.downcase}
        def create
          # TODO: Implement creation logic
          render_json({ status: 'success', message: "#{name} created" }, status: 201)
        end
      end
    RUBY
    File.write(file_name, content)
    puts "Created API Controller: #{file_name}"
    puts "💡 Don't forget to register it in config/routes.rb"
  elsif sub == 'mailer' && name
    action = ARGV.shift || 'welcome'
    class_name = name.capitalize + "Mailer"
    file_name = File.join(PROJECT_ROOT, "app/mailers/#{name.downcase}_mailer.rb")
    content = <<~RUBY
      class #{class_name} < ApplicationMailer
        def #{action}(user)
          mail(
            to: user.email,
            subject: "Welcome to our platform!",
            template: "#{name.downcase}_mailer/#{action}",
            locals: { user: user }
          )
        end
      end
    RUBY
    File.write(file_name, content)
    
    # Create template
    template_dir = File.join(PROJECT_ROOT, "app/views/mailers/#{name.downcase}_mailer")
    FileUtils.mkdir_p(template_dir)
    template_file = File.join(template_dir, "#{action}.erb")
    File.write(template_file, "<h1>Hello <%= @user.username %></h1>\n<p>Welcome to One-For-All Framework!</p>")
    
    puts "Created Mailer: #{file_name}"
    puts "Created Template: #{template_file}"
  elsif sub == 'task' && name
    dir_path = File.join(PROJECT_ROOT, "lib/tasks")
    FileUtils.mkdir_p(dir_path)
    file_name = File.join(dir_path, "#{name.downcase}.rb")
    content = <<~RUBY
      desc "Description for #{name} task"
      task :#{name.downcase} do
        puts "Running task: #{name}"
        # Your background job logic here
      end
    RUBY
    File.write(file_name, content)
    puts "Created Task: #{file_name}"
  elsif sub == 'test' && name
    file_name = File.join(PROJECT_ROOT, "test/#{name.downcase}_test.rb")
    content = <<~RUBY
      require_relative 'test_helper'

      class #{name.capitalize}Test < Minitest::Test
        def test_example
          assert true
        end
      end
    RUBY
    File.write(file_name, content)
    puts "Created Test: #{file_name}"
  elsif sub == 'model' && name
    class_name = name.capitalize
    file_name = File.join(PROJECT_ROOT, "app/models/#{name.downcase}.rb")
    content = <<~RUBY
      class #{class_name} < Sequel::Model
      end
    RUBY
    File.write(file_name, content)
    puts "Created: #{file_name}"
  elsif sub == 'migration' && name
    version = Time.now.strftime('%Y%m%d%H%M%S')
    dir_path = File.join(PROJECT_ROOT, "db/migrations")
    FileUtils.mkdir_p(dir_path)
    file_name = File.join(dir_path, "#{version}_#{name.downcase}.rb")
    content = <<~RUBY
      Sequel.migration do
        change do
        end
      end
    RUBY
    File.write(file_name, content)
    puts "Created migration: #{file_name}"
  elsif sub == 'post' && name
    options = {}
    OptionParser.new do |opts|
      opts.on("--category CAT") { |v| options[:category] = v }
      opts.on("--author AUTH") { |v| options[:author] = v }
      opts.on("--image IMG") { |v| options[:image] = v }
    end.parse!(ARGV)
    dir_path = File.join(PROJECT_ROOT, "app/views/posts")
    FileUtils.mkdir_p(dir_path)
    file_name = File.join(dir_path, "#{name.downcase.gsub(' ', '_')}.erb")
    content = "<h1>#{name}</h1>\n<p>Author: #{options[:author] || 'Admin'}</p>\n<p>Category: #{options[:category] || 'General'}</p>"
    File.write(file_name, content)
    puts "Created post: #{file_name}"
  elsif sub == 'plugin' && name
    dir_path = File.join(PROJECT_ROOT, "plugins/#{name.downcase}")
    FileUtils.mkdir_p(dir_path)
    file_name = File.join(dir_path, "init.rb")
    content = <<~RUBY
      # Plugin: #{name.capitalize}
      # Created at: #{Time.now}

      OFA.on_boot do
        puts "🚀 Plugin #{name.capitalize} loaded!"
      end

      # Example route added by plugin
      # OFA.add_route(:get, '/#{name.downcase}') do |req, res|
      #   res.body << "Hello from #{name.capitalize} Plugin!"
      # end
    RUBY
    File.write(file_name, content)
    puts "Created Plugin: #{dir_path}"
    puts "💡 Edit #{file_name} to start building your plugin."
  else
    puts "Usage: ofa g [controller|api|model|migration|mailer|task|test|post|plugin] NAME"
  end

when 'feature'
  ensure_initialized!
  action = ARGV.shift
  feature = ARGV.shift
  config_path = File.join(PROJECT_ROOT, 'config', 'features.json')
  config = JSON.parse(File.read(config_path))
  config[feature] = (action == 'enable')
  File.open("#{config_path}.tmp", 'w') { |f| f.write(JSON.pretty_generate(config)) }
  File.rename("#{config_path}.tmp", config_path)
  puts "Feature '#{feature}' has been #{action}d."
  
  if action == 'enable' && feature == 'cms' && !config['auth']
    puts "\n⚠️  [WARNING]: You have enabled CMS but 'auth' is disabled."
    puts "   It is highly recommended to enable 'auth' feature to secure your dashboard."
    puts "   Run: ./ofa feature enable auth"
  end

when 'type'
  ensure_initialized!
  name = ARGV.shift
  unless %w[landing_page portfolio blog e_commerce].include?(name)
    puts "❌ Error: Invalid app type '#{name}'. Choose: landing_page, portfolio, blog, e_commerce."
    exit 1
  end
  config_path = File.join(PROJECT_ROOT, 'config', 'features.json')
  config = JSON.parse(File.read(config_path))
  config['type'] = name
  File.open("#{config_path}.tmp", 'w') { |f| f.write(JSON.pretty_generate(config)) }
  File.rename("#{config_path}.tmp", config_path)
  puts "Application type set to '#{name}'."

when 'theme'
  ensure_initialized!
  name = ARGV.shift
  unless %w[light_glass dark_glass cyber_sidebar retro_terminal light_sidebar].include?(name)
    puts "❌ Error: Invalid theme '#{name}'. Choose: light_glass, dark_glass, cyber_sidebar, retro_terminal, light_sidebar."
    exit 1
  end
  config_path = File.join(PROJECT_ROOT, 'config', 'features.json')
  config = JSON.parse(File.read(config_path))
  config['theme'] = name
  File.open("#{config_path}.tmp", 'w') { |f| f.write(JSON.pretty_generate(config)) }
  File.rename("#{config_path}.tmp", config_path)
  puts "Application theme set to '#{name}'."

when 'storage'
  ensure_initialized!
  name = ARGV.shift
  unless %w[local cloudinary].include?(name)
    puts "❌ Error: Invalid storage type '#{name}'. Choose: local, cloudinary."
    exit 1
  end
  config_path = File.join(PROJECT_ROOT, 'config', 'features.json')
  config = JSON.parse(File.read(config_path))
  config['storage'] = name
  File.write(config_path, JSON.pretty_generate(config))
  puts "Application storage set to '#{name}'."

when 'maintenance'
  ensure_initialized!
  action = ARGV.shift
  unless %w[on off].include?(action)
    puts "Usage: ofa maintenance [on|off]"
    exit 1
  end
  config_path = File.join(PROJECT_ROOT, 'config', 'features.json')
  config = JSON.parse(File.read(config_path))
  config['maintenance'] = (action == 'on')
  File.write(config_path, JSON.pretty_generate(config))
  puts "Maintenance mode has been turned #{action}."

when 'reset-password'
  ENV['SKIP_MODELS'] = '1'
  Object.const_set(:APP_ROOT, PROJECT_ROOT) unless defined?(APP_ROOT)
  require File.join(FRAMEWORK_ROOT, 'config', 'boot')
  require File.join(FRAMEWORK_ROOT, 'app', 'models', 'user.rb')
  user_name = ARGV.shift
  new_pwd = ARGV.shift
  if user_name.nil? || new_pwd.nil?
    puts "Usage: ofa reset-password USERNAME PASSWORD"
    exit 1
  end
  begin
    user = User.find(username: user_name) rescue nil
    if user
      user.password = new_pwd
      user.save
      puts "✅ Password for '#{user_name}' has been reset."
    else
      user = User.new(username: user_name)
      user.password = new_pwd
      user.save
      puts "✅ User '#{user_name}' created with the provided password."
    end
  rescue ArgumentError => e
    puts "❌ Error: #{e.message}"
    puts "   Requirements: min 8 characters, one uppercase, one number."
    exit 1
  end

when 'migrate'
  run_migrations

when 'db'
  sub = ARGV.shift
  config_path = File.join(PROJECT_ROOT, 'config', 'database.json')
  case sub
  when 'switch'
    type = ARGV.shift
    db_name = ARGV.shift
    case type
    when 'env', 'mongo', 'mongodb'
      config = { "adapter" => "env" }
      if db_name && db_name.start_with?('mongodb')
        env_path = File.join(PROJECT_ROOT, '.env')
        env_lines = File.exist?(env_path) ? File.readlines(env_path) : []
        env_lines.reject! { |l| l.start_with?('DATABASE_URL=') }
        env_lines << "DATABASE_URL=#{db_name}\n"
        File.open("#{env_path}.tmp", 'w') { |f| f.write(env_lines.join) }
        File.rename("#{env_path}.tmp", env_path)
        puts "✅ Connection string saved to .env"
      end
    when 'sqlite'
      config = { "adapter" => "sqlite", "database" => db_name || "db/development.sqlite3" }
    else
      config = { "adapter" => type, "host" => "localhost", "user" => "root", "password" => "", "database" => db_name || "one_for_all" }
    end
    File.open("#{config_path}.tmp", 'w') { |f| f.write(JSON.pretty_generate(config)) }
    File.rename("#{config_path}.tmp", config_path)
    puts "Switched to #{type} mode."
  when 'migrate'
    run_migrations
  when 'migrate-data'
    target_type = ARGV.shift
    target_name = ARGV.shift
    if target_type.nil?
      puts "Usage: ofa db migrate-data TYPE [NAME/URL]"
      exit 1
    end
    perform_db_migration(target_type, target_name)
  end

when 'doctor'
  puts "🩺 One-For-All Doctor - System Health Check"
  puts "------------------------------------------"
  
  # 1. Environment Check
  print "Checking .env file... "
  if File.exist?('.env')
    puts "✅ Found."
    env_content = File.read('.env')
    if env_content.include?('DATABASE_URL')
      puts "  - DATABASE_URL: Defined"
    end
  else
    puts "❌ Missing! Create a .env file based on .env.example."
  end

  # 2. Database Check
  print "Checking Database connection... "
  begin
    Object.const_set(:APP_ROOT, PROJECT_ROOT) unless defined?(APP_ROOT)
    ENV['EKS_ENV'] = 'test' # Silence some output
    require File.join(FRAMEWORK_ROOT, 'config', 'boot')
    if defined?(DB) && DB.test_connection
      puts "✅ Connected (#{DB_CONFIG['adapter']})"
    else
      puts "❌ Failed!"
    end
    
    if defined?(MONGO_CLIENT)
      print "Checking MongoDB connection... "
      begin
        MONGO_CLIENT.database_names
        puts "✅ Connected"
      rescue => e
        puts "❌ Failed: #{e.message}"
      end
    end
  rescue => e
    puts "❌ Error during boot: #{e.message}"
  end

  # 3. Ruby Version
  print "Checking Ruby version... "
  puts "✅ #{RUBY_VERSION}"

  # 4. Gems Check
  print "Checking dependencies... "
  if File.exist?('Gemfile.lock')
    puts "✅ Gemfile.lock exists."
  else
    puts "⚠️  Gemfile.lock not found. Run 'bundle install'."
  end

  # 5. Features Config
  print "Checking features.json... "
  if File.exist?('config/features.json')
    puts "✅ Found."
  else
    puts "❌ Missing! Run 'ofa init'."
  end

  puts "------------------------------------------"
  puts "Doctor check complete! ✨"

when 'console'
  ensure_initialized!
  puts "                                            "
  puts "   ____  _______  ___                       "
  puts "  / __ \\/ ____/  /   |                      "
  puts " / / / / /_     / /| |  Framework           "
  puts "/ /_/ / __/    / ___ |  Console (REPL)      "
  puts "\\____/_/      /_/  |_|  v5.3.0              "
  puts "                                            "
  puts "✨ Loading environment... (Type 'exit' to quit)"
  
  Object.const_set(:APP_ROOT, PROJECT_ROOT) unless defined?(APP_ROOT)
  require File.join(FRAMEWORK_ROOT, 'config', 'boot')
  
  require 'irb'
  ARGV.clear
  IRB.start

when 'routes'
  ensure_initialized!
  puts "🗺️  Registered Routes"
  puts "--------------------------------------------------------"
  printf "%-8s | %-40s\n", "Verb", "Path"
  puts "--------------------------------------------------------"
  
  Object.const_set(:APP_ROOT, PROJECT_ROOT) unless defined?(APP_ROOT)
  ENV['EKS_ENV'] = 'test'
  require File.join(FRAMEWORK_ROOT, 'config', 'boot')
  
  if defined?(ROUTES)
    routes_hash = ROUTES.instance_variable_get(:@routes)
    routes_hash.each do |verb, list|
      list.each do |r|
        printf "%-8s | %-40s\n", verb, r[:path]
      end
    end
  else
    puts "❌ No routes found."
  end
  puts "--------------------------------------------------------"

when 'swagger'
  ensure_initialized!
  puts "📝 Generating OpenAPI 3.0 documentation..."
  
  Object.const_set(:APP_ROOT, PROJECT_ROOT) unless defined?(APP_ROOT)
  ENV['EKS_ENV'] = 'test'
  require File.join(FRAMEWORK_ROOT, 'config', 'boot')
  
  openapi = {
    openapi: "3.0.0",
    info: {
      title: "#{File.basename(PROJECT_ROOT)} API",
      version: "1.0.0",
      description: "Auto-generated by One-For-All Framework"
    },
    paths: {}
  }
  
  if defined?(ROUTES)
    routes_hash = ROUTES.instance_variable_get(:@routes)
    routes_hash.each do |verb, list|
      list.each do |r|
        path = r[:path].gsub(/:(\w+)/, '{\1}') # Convert :id to {id}
        openapi[:paths][path] ||= {}
        openapi[:paths][path][verb.to_s.downcase] = {
          summary: "Endpoint for #{path}",
          responses: {
            "200" => { description: "Successful response" }
          }
        }
        
        # Add parameters if dynamic path
        if path.include?('{')
          params = path.scan(/\{(\w+)\}/).flatten
          openapi[:paths][path][verb.to_s.downcase][:parameters] = params.map do |p|
            { name: p, in: "path", required: true, schema: { type: "string" } }
          end
        end
      end
    end
  end
  
  output_path = File.join(PROJECT_ROOT, 'openapi.json')
  File.write(output_path, JSON.pretty_generate(openapi))
  puts "✅ Documentation saved to: #{output_path}"
  puts "💡 You can paste this into https://editor.swagger.io to view it."

when 'run'
  ensure_initialized!
  # Check for config.ru
  unless File.exist?(File.join(PROJECT_ROOT, 'config.ru'))
    puts "Error: config.ru not found. Ensure you are in the project root or run 'ofa init'."
    exit 1
  end
  puts "Starting One-For-All server..."
  exec "bundle exec eksa-server"

when 'deploy'
  puts "🚀 Starting Deployment process..."
  puts "-----------------------------"
  
  # 1. Check for Git
  unless system("git rev-parse --is-inside-work-tree > /dev/null 2>&1")
    puts "❌ Error: Project not initialized with Git."
    puts "   Please run 'git init' and commit your changes first."
    exit 1
  end

  # 2. Check for Railway CLI as an example of deployment target
  if system("railway --version > /dev/null 2>&1")
    puts "📦 Railway CLI detected. Deploying to Railway..."
    exec "railway up"
  else
    puts "⚠️  Deployment target not detected (Railway/Vercel)."
    puts "   Suggestion: Install Railway CLI or prepare a Dockerfile for VPS."
    puts "   This framework supports deployment via Docker or Git Push."
  end

when 'task'
  ensure_initialized!
  name = ARGV.shift
  if name.nil?
    puts "Usage: ofa task NAME"
    # List available tasks
    tasks_dir = File.join(PROJECT_ROOT, 'lib/tasks')
    if Dir.exist?(tasks_dir)
      puts "\nAvailable tasks:"
      Dir.glob(File.join(tasks_dir, '*.rb')).each do |f|
        puts "  - #{File.basename(f, '.rb')}"
      end
    end
    exit 1
  end
  
  # Load framework & app
  Object.const_set(:APP_ROOT, PROJECT_ROOT) unless defined?(APP_ROOT)
  require File.join(FRAMEWORK_ROOT, 'config', 'boot')
  require File.join(FRAMEWORK_ROOT, 'lib', 'task_helper')
  
  # Load all tasks in lib/tasks
  Dir.glob(File.join(PROJECT_ROOT, 'lib/tasks/*.rb')).each { |f| require f }
  
  run_task(name)

when 'test'
  ensure_initialized!
  puts "🧪 Running tests..."
  puts "------------------------------------------"
  
  # Set environment to test
  ENV['EKS_ENV'] = 'test'
  Object.const_set(:APP_ROOT, PROJECT_ROOT) unless defined?(APP_ROOT)
  
  # Add project root to load path
  $LOAD_PATH.unshift PROJECT_ROOT
  $LOAD_PATH.unshift File.join(PROJECT_ROOT, 'test')
  
  # Find all tests (support both _test.rb and _spec.rb)
  if ARGV.empty?
    test_files = Dir.glob(File.join(PROJECT_ROOT, 'test/**/{*_test.rb,*_spec.rb}'))
  else
    test_files = ARGV.map { |arg| File.expand_path(arg, PROJECT_ROOT) }
  end
  
  if test_files.empty?
    puts "❌ No tests found in test/ directory."
    exit 1
  end
  
  # Run them by requiring
  test_files.each { |f| require f }

  # Trigger EksaMination execution if available
  EksaMination.run if defined?(EksaMination)

else
  help
end
